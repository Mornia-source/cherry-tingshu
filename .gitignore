# ===== 樱桃听书 .gitignore =====
# 语音引擎本体（太大，不随项目分发；用户自行下载后在网页里配置路径）
GPT-SoVITS*/
index-tts/
IndexTTS*/

# 模型权重 / 参考音频（大文件、可能有版权，仅本机自用）
model/
output/

# 用户数据：账号库、头像、封面、预生成音频缓存、导出包
data/

# 用户书籍
ebook/

# 个人配置（含本机绝对路径与私人声线）—— 用 config.example.json 作模板
config.json

# 测试/临时产物
_*.wav
*.zip
*.log

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# 手机端 Capacitor 打包产物（由 打包APK.bat 生成，不入库）
mobile/node_modules/
mobile/android/
mobile/www/
mobile/package.json
mobile/package-lock.json
mobile/capacitor.config.json
mobile/capacitor.config.ts
mobile/*.apk

# 编辑器/系统
.vscode/
.idea/
.DS_Store
Thumbs.db
